# PostgreSQL (used by docker-compose for the postgres container)
POSTGRES_PASSWORD=change-me-strong-password

# The app container overrides DATABASE_URL via docker-compose.yml,
# but set it here if running outside Docker:
# DATABASE_URL=postgres://gravegoods:yourpassword@localhost:5432/grave_goods

PORT=4000
FRONTEND_URL=https://gravegoodsgoodies.com
NODE_ENV=production

# Admin bootstrap
ADMIN_EMAIL=admin@gravegoodsgoodies.com
ADMIN_PASSWORD=change-me-admin
ADMIN_FULL_NAME=Store Admin

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=gravegoodsgoodies/products
